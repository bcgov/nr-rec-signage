{
  "name": "quickstart-openshift-react-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "clean": "rimraf ./node_modules/.vite",
    "build:analyze": "vite build --mode analyze",
    "build:clean": "rimraf dist",
    "deploy": "npm ci --ignore-scripts --no-update-notifier --omit=dev && npm run build",
    "preview": "vite preview",
    "test:unit": "vitest --mode test",
    "test:cov": "vitest run --mode test --coverage",
    "build": "vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"e2e/**/*.ts\" \"*.config.ts\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"e2e/**/*.ts\" \"*.config.ts\" --fix"
  },
  "dependencies": {
    "@bcgov/bc-sans": "^2.1.0",
    "@bcgov/design-system-react-components": "^0.6.0",
    "@popperjs/core": "^2.11.8",
    "@tanstack/router-plugin": "^1.114.27",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "axios": "^1.14.0",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "dom-to-svg": "^0.12.2",
    "font-awesome": "^4.7.0",
    "imagetracerjs": "^1.2.6",
    "keycloak-js": "^26.2.3",
    "opentype.js": "^1.3.4",
    "react": "^19.0.0",
    "react-bootstrap": "^2.10.9",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.0",
    "react-svg": "^17.2.4",
    "sass-embedded": "^1.86.0",
    "uuid": "^13.0.0",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.15.0",
    "@faker-js/faker": "^10.0.0",
    "@playwright/test": "^1.51.0",
    "@tanstack/react-router-devtools": "^1.114.13",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/opentype.js": "^1.3.9",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/ui": "^4.0.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-cypress": "^5.0.0",
    "eslint-plugin-html": "^8.1.2",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-tsdoc": "^0.5.0",
    "globals": "^17.0.0",
    "history": "^5.3.0",
    "jsdom": "^28.0.0",
    "msw": "^2.7.3",
    "playwright": "^1.51.0",
    "prettier": "^3.5.3",
    "sass": "^1.85.1",
    "typescript": "^5.7.3",
    "vitest": "^4.0.0"
  }
}
